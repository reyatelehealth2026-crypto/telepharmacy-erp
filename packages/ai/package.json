{
  "name": "@telepharmacy/ai",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./chatbot": {
      "types": "./dist/chatbot.d.ts",
      "import": "./dist/chatbot.js",
      "require": "./dist/chatbot.js"
    },
    "./ocr": {
      "types": "./dist/ocr.d.ts",
      "import": "./dist/ocr.js",
      "require": "./dist/ocr.js"
    },
    "./drug-checker": {
      "types": "./dist/drug-checker.d.ts",
      "import": "./dist/drug-checker.js",
      "require": "./dist/drug-checker.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@ai-sdk/google": "^1",
    "ai": "^4",
    "zod": "^3"
  },
  "devDependencies": {
    "typescript": "^5"
  }
}
