{
  "name": "@telepharmacy/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "nest start",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "test": "jest",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@anatine/zod-nestjs": "^2",
    "@nestjs/bull": "^11.0.4",
    "@nestjs/common": "^11.1",
    "@nestjs/config": "^4",
    "@nestjs/core": "^11.1",
    "@nestjs/jwt": "^11",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/passport": "^11",
    "@nestjs/platform-express": "^11.1",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/terminus": "^11",
    "@nestjs/throttler": "^6",
    "@telepharmacy/db": "workspace:*",
    "@telepharmacy/shared": "workspace:*",
    "bcryptjs": "^2",
    "bull": "^4.16.5",
    "class-transformer": "^0.5",
    "class-validator": "^0.14",
    "drizzle-orm": "^0.39",
    "express": "^5.2.1",
    "helmet": "^8",
    "ioredis": "^5.10.1",
    "meilisearch": "^0.47",
    "passport": "^0.7",
    "passport-jwt": "^4",
    "passport-local": "^1",
    "postgres": "^3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7",
    "zod": "^3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@telepharmacy/db$": "<rootDir>/../../../packages/db/src/index.ts",
      "^@telepharmacy/ai$": "<rootDir>/../../../packages/ai/src/index.ts",
      "^@telepharmacy/ai/(.*)$": "<rootDir>/../../../packages/ai/src/$1.ts"
    }
  },
  "devDependencies": {
    "@nestjs/cli": "^11",
    "@nestjs/schematics": "^11",
    "@nestjs/testing": "^11.1",
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.21",
    "@types/bcryptjs": "^2",
    "@types/express": "^5",
    "@types/jest": "^29",
    "@types/node": "^22",
    "@types/passport-jwt": "^4",
    "@types/passport-local": "^1",
    "jest": "^29",
    "source-map-support": "^0.5",
    "ts-jest": "^29",
    "ts-node": "^10",
    "tsconfig-paths": "^4",
    "typescript": "^5"
  }
}
