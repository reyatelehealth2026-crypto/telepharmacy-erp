{
  "name": "telepharmacy-erp",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build && pnpm postbuild",
    "postbuild": "pnpm postbuild:admin && pnpm postbuild:shop",
    "postbuild:admin": "cp -r apps/admin/.next/static apps/admin/.next/standalone/apps/admin/.next/ && cp -r apps/admin/public apps/admin/.next/standalone/apps/admin/ || true",
    "postbuild:shop": "cp -r apps/shop/.next/static apps/shop/.next/standalone/apps/shop/.next/ && cp -r apps/shop/public apps/shop/.next/standalone/apps/shop/ || true",
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=@telepharmacy/api",
    "dev:admin": "turbo run dev --filter=@telepharmacy/admin",
    "dev:shop": "turbo run dev --filter=@telepharmacy/shop",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "db:generate": "turbo run db:generate --filter=@telepharmacy/db",
    "db:migrate": "turbo run db:migrate --filter=@telepharmacy/db",
    "db:push": "turbo run db:push --filter=@telepharmacy/db",
    "db:seed": "pnpm --filter @telepharmacy/db db:seed",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@swc/core",
      "esbuild",
      "sharp"
    ]
  },
  "devDependencies": {
    "turbo": "^2",
    "prettier": "^3",
    "typescript": "^5"
  }
}
