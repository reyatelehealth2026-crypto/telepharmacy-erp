# ---- Telemedicine 2569 Compliance ----------------------------
# AWS Rekognition for face verification (Thailand region)
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Agora.io for video consultations
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# ThaiSMS for OTP delivery
THAI_SMS_API_KEY=
THAI_SMS_SENDER=

# Audit trail encryption
AUDIT_ENCRYPTION_KEY=change-me-to-64-char-hex-string

# Thai Pharmacy Council API (if available)
PHARMACY_COUNCIL_API_URL=
PHARMACY_COUNCIL_API_KEY=

# ---- JWT Secrets ---------------------------------------------
JWT_SECRET=change-me-to-a-random-secret
JWT_REFRESH_SECRET=change-me-to-another-random-secret
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ---- Prescription Digital Signature (Thai Pharmacy Act) ------
PRESCRIPTION_SIGNING_SECRET=change-me-to-a-secure-random-secret

# ---- Meilisearch ---------------------------------------------
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=change-me-to-a-random-key

# ---- LIFF / Shop (public, exposed to browser) ----------------
NEXT_PUBLIC_LIFF_ID=
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_SHOP_URL=http://localhost:3002

# ---- Admin Dashboard -----------------------------------------
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:3000

# ---- Odoo ERP Integration ------------------------------------
ODOO_BASE_URL=https://erp.cnyrxapp.com
ODOO_API_USER=
ODOO_API_TOKEN=
ODOO_SYNC_INTERVAL_MS=1800000
ODOO_STOCK_CACHE_TTL_SEC=300

# ---- App Settings --------------------------------------------
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
